---
// src/pages/writing/index.astro
// Archive view of all blog posts. Quiet, editorial, no loud hero.
// Posts are pulled from the 'writing' collection (configured below).

import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Writing — The Brand Whisperer"
  description="Field notes on branding, startups, and scaling design systems."
  canonical="https://brandwhisperer.io/writing"
>
  <main class="writing-archive">
    <header class="writing-archive__head">
      <Nav />
      <div class="writing-archive__title-row">
        <span class="bw-label bw-muted">FIELD NOTES</span>
        <h1 class="writing-archive__title bw-d2 bw-paper">Writing.</h1>
        <p class="writing-archive__sub bw-body bw-muted-strong">
          Thinking out loud about brands, type, and scale. Cross-posted from LinkedIn; the archive lives here.
        </p>
      </div>
    </header>

    <ol class="post-list" role="list">
      {posts.length === 0 ? (
        <li class="post-list__empty bw-muted">No posts yet. Check back soon.</li>
      ) : (
        posts.map((post) => (
          <li class="post-list__item">
            <a class="post-list__link" href={`/writing/${post.slug}/`}>
              <time class="post-list__date bw-label bw-label--tag bw-muted" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <h2 class="post-list__title bw-d3 bw-paper">{post.data.title}</h2>
              {post.data.summary && (
                <p class="post-list__summary bw-body bw-muted-strong">{post.data.summary}</p>
              )}
            </a>
          </li>
        ))
      )}
    </ol>
  </main>
</BaseLayout>

<style>
  .writing-archive {
    max-width: 820px;
    margin: 0 auto;
    padding: var(--bw-pad-v) var(--bw-pad-h);
  }
  .writing-archive__head { margin-bottom: 64px; }
  .writing-archive__title-row {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 72px;
  }
  .writing-archive__title { margin: 0; }
  .writing-archive__sub { max-width: 480px; }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .post-list__empty { padding: 24px 0; }
  .post-list__item {
    border-top: var(--bw-hairline-soft);
  }
  .post-list__item:last-child {
    border-bottom: var(--bw-hairline-soft);
  }
  .post-list__link {
    display: block;
    padding: 24px 0;
    transition: opacity 0.12s ease;
  }
  .post-list__link:hover,
  .post-list__link:focus-visible {
    opacity: 0.82;
  }
  .post-list__date { display: block; margin-bottom: 10px; }
  .post-list__title { margin: 0 0 8px; font-size: clamp(22px, 3vw, 32px); }
  .post-list__summary { margin: 0; max-width: 580px; }
</style>
