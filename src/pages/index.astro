---
// src/pages/index.astro
// The Brand Whisperer landing page — five folds.
//
// Content comes from `src/content/landing/default.json` (typed via
// `src/content/config.ts`). To migrate to EmDash: replace the
// `getEntry('landing', 'default')` call with a Live Collection query
// from `src/live.config.ts`. Component shapes are identical.

import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

import Fold           from '../components/Fold.astro';
import Nav            from '../components/Nav.astro';
import PageMarker     from '../components/PageMarker.astro';
import HeroStatement  from '../components/HeroStatement.astro';
import PullQuote      from '../components/PullQuote.astro';
import ProseBlock     from '../components/ProseBlock.astro';
import NamesWall      from '../components/NamesWall.astro';
import TierRow        from '../components/TierRow.astro';
import CloseCTA       from '../components/CloseCTA.astro';

const entry = await getEntry('landing', 'default');
if (!entry) throw new Error('Missing landing content at src/content/landing/default.json');
const { hero, who, work, engage, close } = entry.data;

const TOTAL = 5;
---

<BaseLayout
  title="The Brand Whisperer — Building brands that don't break at Series A"
  canonical="https://brandwhisperer.io"
>
  <main>
    {/* ── Fold 1 ── HERO ─────────────────────────────── */}
    <Fold id="hero" label="Hero statement">
      <Nav slot="top" />
      <HeroStatement text={hero.statement} />
      <PageMarker slot="bottom" current={1} total={TOTAL} label={hero.footerLine} />
    </Fold>

    {/* ── Fold 2 ── WHO ──────────────────────────────── */}
    <Fold id="who" label="Who I am">
      <Nav slot="top" />
      <div class="who-grid">
        <PullQuote accent={who.pullAccent} counter={who.pullCounter} />
        <ProseBlock paragraphs={who.paragraphs} />
      </div>
      <PageMarker slot="bottom" current={2} total={TOTAL} label="02 · WHO" />
    </Fold>

    {/* ── Fold 3 ── WORK ─────────────────────────────── */}
    <Fold id="work" label="Selected work">
      <Nav slot="top" />
      <NamesWall entries={work.entries} tally={work.tally} />
      <PageMarker slot="bottom" current={3} total={TOTAL} label="03 · WORK" />
    </Fold>

    {/* ── Fold 4 ── ENGAGE ───────────────────────────── */}
    <Fold id="engage" label="Engagement tiers" size="tall">
      <Nav slot="top" />
      <div class="engage">
        <div class="engage__label bw-label">{engage.label}</div>
        <div class="engage__tiers">
          {engage.tiers.map((t, i) => <TierRow {...t} first={i === 0} />)}
        </div>
      </div>
      <PageMarker slot="bottom" current={4} total={TOTAL} label="04 · ENGAGE" />
    </Fold>

    {/* ── Fold 5 ── CLOSE ────────────────────────────── */}
    <Fold id="contact" label="Contact">
      <Nav slot="top" />
      <CloseCTA leadIn={close.leadIn} statement={close.statement} email={close.email} />
      <PageMarker slot="bottom" current={5} total={TOTAL} label="05 · CONTACT" last />
    </Fold>
  </main>
</BaseLayout>

<style>
  main {
    max-width: var(--bw-container);
    margin: 0 auto;
  }

  /* Fold 2 layout: pullout (left) + prose (right) */
  .who-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    padding: 16px 0;
  }
  @media (max-width: 820px) {
    .who-grid {
      grid-template-columns: 1fr;
      gap: var(--bw-gap-md);
    }
  }

  /* Fold 4 layout */
  .engage { padding: 16px 0; }
  .engage__label {
    font-size: var(--bw-size-tag);
    letter-spacing: var(--bw-ls-caps-wide);
    color: var(--bw-paper-45);
    margin-bottom: 28px;
  }
</style>
